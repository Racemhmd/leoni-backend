# ── Base de données PostgreSQL ───────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME
DB_NAME=leoni_db
DB_SYNCHRONIZE=false        # true en développement uniquement

# ── JWT ──────────────────────────────────────────────────────────────────────
# Générer avec : node -e "require('crypto').randomBytes(32).toString('hex') |> console.log"
JWT_SECRET=CHANGE_ME_GENERATE_STRONG_SECRET_32_CHARS_MIN

# ── Serveur ──────────────────────────────────────────────────────────────────
PORT=3000

# ── Mots de passe seeds (remplacés au 1er login via mustChangePassword=true) ─
SEED_ADMIN_PASSWORD=CHANGE_ME_ADMIN
SEED_EMPLOYEE_PASSWORD=CHANGE_ME_EMPLOYEE
SEED_BULK_PASSWORD=CHANGE_ME_BULK

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_google_app_password
EMAIL_FROM=your_email@gmail.com

# ── SMS (Twilio) ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMS_SENDER_ID=+21600000000      # ou numéro Twilio

# ── Push (Firebase) ──────────────────────────────────────────────────────────
# Service account encodé en base64 :
#   base64 -i serviceAccountKey.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT=
